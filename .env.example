# Supabase PostgreSQL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Transaction pooler
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=maintenance_knowledge

# LLM
OPENAI_API_KEY=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_PRIMARY=qwen
LLM_FALLBACK=gpt4o

# Streaming
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MQTT_BROKER=localhost:1883

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=maintenance123

# App
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=INFO

# Alerting
SMTP_HOST=
SMTP_PORT=587
ALERT_EMAIL_FROM=alerts@maintenance.ai
